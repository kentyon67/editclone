# ===== Backend (FastAPI) =====

# CORS: フロントエンドのURL (カンマ区切りで複数指定可)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Whisperモデルサイズ: tiny / base / small / medium / large
# tiny=75MB / base=145MB / small=461MB / medium=1.5GB
WHISPER_MODEL=base

# ===== Frontend (Next.js) =====

# FastAPIバックエンドのURL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase (https://supabase.com でプロジェクト作成後に取得)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe (https://stripe.com でアカウント作成後に取得)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripeの料金ID (Stripe DashboardでProductを作成後に取得)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_CREATOR=price_...
STRIPE_PRICE_STUDIO=price_...
