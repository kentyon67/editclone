# ===== Backend (FastAPI / Railway) =====

# CORS: フロントエンドのURL (カンマ区切りで複数指定可)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Whisperモデルサイズ: tiny / base / small / medium / large
# tiny=75MB / base=145MB / small=461MB / medium=1.5GB
WHISPER_MODEL=base

# Supabase service-role key (secret — backend only, never expose to browser)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Personal Access Token — マイグレーション自動実行に必要
# 取得先: https://supabase.com/dashboard/account/tokens
# Railway の環境変数に設定すると起動時に自動でスキーマが同期される
SUPABASE_ACCESS_TOKEN=sbp_...

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (backend)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripeの料金ID (Stripe DashboardでProductを作成後に取得)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_CREATOR=price_...
STRIPE_PRICE_STUDIO=price_...

# Git SHA injected at build time (optional — surfaced by GET /metrics/version)
GIT_SHA=

# ===== Frontend (Next.js / Vercel) =====

# FastAPIバックエンドのURL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase public keys (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe publishable key (safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
